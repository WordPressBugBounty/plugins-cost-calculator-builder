## API Calls

### Create API Service

```typescript
// services/api.service.ts

import axios, { AxiosResponse } from 'axios';

const API_URL = (window as any).ajaxurl;

interface ApiResponse<T> {
  success: boolean;
  data: T;
}

export const api = {
  async getCalculator(id: number): Promise<ApiResponse<ICalculator>> {
    const response = await axios.post(API_URL, {
      action: 'calc_get_calculator',
      nonce: (window as any).ccb_nonces.get_calculator,
      id,
    });
    return response.data;
  },

  async saveCalculator(data: ICalculator): Promise<ApiResponse<void>> {
    const response = await axios.post(API_URL, {
      action: 'calc_save_calculator',
      nonce: (window as any).ccb_nonces.save_calculator,
      ...data,
    });
    return response.data;
  },
};
```

### Use in Components/Stores

```typescript
// In store action
async fetchCalculator(id: number) {
    try {
        const response = await api.getCalculator(id);
        if (response.success) {
            this.calculator = response.data;
        }
    } catch (error) {
        console.error('Failed to fetch calculator:', error);
    }
}
```

## Reactivity

### Ref vs Reactive

```typescript
// ✅ Good - Use ref for primitives with explicit types
const count = ref<number>(0);
const message = ref<string>('');
const isActive = ref<boolean>(false);

// ✅ Good - Use ref for objects too (easier to replace)
const user = ref<IUser | null>(null);
user.value = newUser;

// ⚠️ Reactive - can be used, but ref is preferred
const state = reactive({
  count: 0,
  message: '',
});

// ❌ Don't destructure reactive
const { count } = reactive({ count: 0 }); // Loses reactivity
```

### Computed vs Method

```typescript
// ✅ Good - Use computed for derived state
const double = computed(() => count.value * 2);

// ✅ Good - Use method for actions/events
function increment() {
  count.value++;
}

// ❌ Bad - Method for derived state (recalculated every render)
function getDouble() {
  return count.value * 2;
}
```

## Watchers

```typescript
// ✅ Good - Watch single source
watch(
  () => props.calculatorId,
  (newId) => {
    loadCalculator(newId);
  }
);

// ✅ Good - Watch multiple sources
watch([count, message], ([newCount, newMessage]) => {
  console.log(newCount, newMessage);
});

// ✅ Good - Deep watch
watch(
  () => props.calculator,
  (newVal) => {
    console.log('Calculator changed');
  },
  { deep: true }
);

// ⚠️ Immediate watch
watch(
  () => props.calculatorId,
  (newId) => {
    loadCalculator(newId);
  },
  { immediate: true } // Will be called immediately
);
```

## Conditional Rendering

```vue
<template>
  <!-- ✅ Good - v-if for expensive components -->
  <ExpensiveComponent v-if="isVisible" />

  <!-- ✅ Good - v-show for toggle visibility -->
  <div v-show="isVisible">Content</div>

  <!-- ✅ Good - v-for with :key -->
  <div v-for="field in fields" :key="field.alias">
    {{ field.label }}
  </div>

  <!-- ❌ Bad - No key -->
  <div v-for="field in fields">
    {{ field.label }}
  </div>
</template>
```

## Events

```vue
<script setup lang="ts">
// ✅ Good - Typed emits
const emit = defineEmits<{
  save: [id: number];
  update: [field: IField];
}>();

function handleSave() {
  emit('save', calculatorId);
}

// ✅ Good - Event with data
