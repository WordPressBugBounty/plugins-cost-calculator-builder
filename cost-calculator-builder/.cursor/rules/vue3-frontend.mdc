<template>
  <!-- ✅ Good - Named handler -->
  <button @click="handleSave">Save</button>

  <!-- ✅ Good - Inline for simple -->
  <button @click="count++">Increment</button>

  <!-- ❌ Bad - Complex logic inline -->
  <button
    @click="
      loading = true;
      fetchData();
      loading = false;
    "
  >
    Load
  </button>
</template>
```

