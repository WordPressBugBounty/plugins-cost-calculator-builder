## Performance

### Lazy Loading Components

```typescript
// ✅ Good - Lazy load heavy components
const HeavyComponent = defineAsyncComponent(
  () => import('./HeavyComponent.vue')
);
```

### Computed Caching

```typescript
// ✅ Good - Computed caches result
const expensiveValue = computed(() => {
  return fields.value.reduce((sum, f) => sum + f.value, 0);
});

// ❌ Bad - Method recalculates every time
function getExpensiveValue() {
  return fields.value.reduce((sum, f) => sum + f.value, 0);
}
```

### V-Once for Static Content

```vue
<template>
  <!-- ✅ Good - Render once -->
  <div v-once>
    <h1>{{ staticTitle }}</h1>
    <p>{{ staticDescription }}</p>
  </div>
</template>
```

## Error Handling

```typescript
// In store/composable
async function fetchCalculator(id: number) {
  try {
    loading.value = true;
    const response = await api.getCalculator(id);

    if (!response.success) {
      throw new Error(response.data || 'Failed to fetch');
    }

    calculator.value = response.data;
    error.value = null;
  } catch (err) {
    error.value = err instanceof Error ? err.message : 'Unknown error';
    console.error('Error fetching calculator:', err);
  } finally {
    loading.value = false;
  }
}
```

## Testing Considerations

```typescript
// ✅ Good - Pure functions easy to test
function calculateTotal(fields: IField[]): number {
  return fields.reduce((sum, field) => sum + field.value, 0);
}

// ✅ Good - Expose testable methods
export function useCalculator() {
  // ...

  return {
    calculator,
    loading,
    fetchCalculator,
    // Expose for testing
    _test: {
      calculateTotal,
    },
  };
}
```

