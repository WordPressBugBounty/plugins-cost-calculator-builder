## File Structure

```
frontend/vue3/src/admin/
├── app/
│   └── providers/
│       └── stores/           # Pinia stores
├── features/                 # Feature modules
│   ├── builder/
│   ├── conditions/
│   ├── settings/
│   └── flow/
└── shared/                   # Shared resources
    ├── types/               # TypeScript types
    ├── ui/components/       # UI components
    └── utils/               # Utilities
```

## Naming Conventions

### Files

```typescript
// ✅ Good
MyComponent.vue; // Components - PascalCase
useMyStore.ts; // Stores - camelCase with 'use' prefix
myTypes.type.ts; // Types - camelCase + .type.ts
myUtils.ts; // Utils - camelCase
myService.ts; // Services - camelCase

// ❌ Bad
my - component.vue; // Wrong case
MyStore.ts; // Missing 'use' prefix
types.ts; // Not descriptive
```

### Components

```vue
<!-- ✅ Good -->
<script setup lang="ts">
// PascalCase for components
import CalculatorField from './CalculatorField.vue';
import BuilderSidebar from './BuilderSidebar.vue';
</script>

<template>
  <CalculatorField />
  <BuilderSidebar />
</template>

<!-- ❌ Bad -->
<calculator-field />
<!-- kebab-case in import -->
```

### Variables & Functions

```typescript
// ✅ Good
const calculatorId = ref<number>(0);
const builderFields = ref<IField[]>([]);
const isLoading = computed(() => store.loading);

function saveCalculator() {}
function handleFieldUpdate() {}

// ❌ Bad
const CalculatorId = ref(0); // PascalCase for variables
const builder_fields = ref([]); // snake_case
function SaveCalculator() {} // PascalCase for functions
```

### Types & Interfaces

```typescript
// ✅ Good
interface ICalculator {}
interface IField {}
type builderContentType = 'calculator' | 'settings';

// ❌ Bad
interface Calculator {} // Without I prefix
type BuilderContent = 'calculator' | 'settings'; // PascalCase
```

## TypeScript

### Always Use TypeScript

```vue
<!-- ✅ Good -->
<script setup lang="ts">
import { ref } from 'vue';

const count = ref<number>(0);
</script>

<!-- ❌ Bad -->
<script setup>
// No TypeScript
</script>
```

### 🔴 CRITICAL: Always Use Explicit Types with Ref

**Never rely on type inference for refs.** Always specify the type explicitly:

```typescript
// ✅ Good - Explicit types
const count = ref<number>(0);
const message = ref<string>('');
const isActive = ref<boolean>(false);
const items = ref<IField[]>([]);

// ❌ Bad - Relying on inference
const count = ref(0);
const message = ref('');
const items = ref([]);
```

### Props Typing

```vue
<script setup lang="ts">
// ✅ Good - Explicit interface
interface Props {
  calculatorId: number;
  title: string;
  fields?: IField[];
}

const props = withDefaults(defineProps<Props>(), {
  fields: () => [],
});

// ❌ Bad - No types
const props = defineProps({
  calculatorId: Number,
  title: String,
});
</script>
```

### Emits Typing

```vue
<script setup lang="ts">
// ✅ Good
const emit = defineEmits<{
  'update:modelValue': [value: string];
  save: [id: number, data: ICalculator];
  cancel: [];
}>();

// Usage
emit('update:modelValue', 'new value');
emit('save', 123, calculatorData);

// ❌ Bad - No types
const emit = defineEmits(['update:modelValue', 'save']);
</script>
```

### Refs Typing

**Always provide explicit types for refs, even when TypeScript could infer them.**

```typescript
// ✅ Good - Explicit types
const count = ref<number>(0);
const message = ref<string>('');
const isActive = ref<boolean>(false);
const myInput = ref<HTMLInputElement | null>(null);
const calculator = ref<ICalculator | null>(null);
const items = ref<IField[]>([]);

// ❌ Bad - No explicit types (relies on inference)
const count = ref(0); // Inferred but not explicit
const message = ref(''); // Inferred as string but not explicit
const myInput = ref(null); // any type
const items = ref([]); // any[]
```

## Composition API

### Use Composition API (not Options API)

```vue
<!-- ✅ Good - Composition API -->
<script setup lang="ts">
import { ref, computed, onMounted } from 'vue';

const count = ref<number>(0);
const double = computed(() => count.value * 2);

onMounted(() => {
  console.log('Component mounted');
});
</script>

<!-- ❌ Bad - Options API (legacy) -->
<script>
export default {
  data() {
    return { count: 0 };
  },
  computed: {
    double() {
      return this.count * 2;
    },
  },
};
</script>
```

### Script Setup

```vue
<!-- ✅ Good - Use <script setup> -->
<script setup lang="ts">
import { ref } from 'vue';

const count = ref<number>(0);
const increment = () => count.value++;
</script>

<!-- ❌ Bad - Verbose setup() -->
<script lang="ts">
import { ref } from 'vue';

export default {
  setup() {
    const count = ref<number>(0);
    const increment = () => count.value++;

    return {
      count,
      increment,
    };
  },
};
</script>
```

### Composables

```typescript
// composables/useCalculator.ts

// ✅ Good
export function useCalculator(calculatorId: number) {
    const loading = ref<boolean>(false);
    const calculator = ref<ICalculator | null>(null);

    async function loadCalculator() {
        loading.value = true;
        try {
            const response = await api.getCalculator(calculatorId);
            calculator.value = response.data;
        } catch (error) {
            console.error(error);
        } finally {
            loading.value = false;
        }
    }

    return {
        loading,
        calculator,
        loadCalculator
    };
}

// Usage in component
<script setup lang="ts">
const { loading, calculator, loadCalculator } = useCalculator(123);
</script>
```

## Pinia Stores

### Store Structure

```typescript
// stores/useBuilderStore.ts

// ✅ Good
import { defineStore } from 'pinia';

interface IBuilderStore {
  rawFields: IField[];
  builderFields: IPageBreaker[];
}

export const useBuilderStore = defineStore('builder_store', {
  state: (): IBuilderStore => ({
    rawFields: [],
    builderFields: [],
  }),

  getters: {
    getRawFields: (state): IField[] => state.rawFields,

    getFieldByAlias: (state) => {
      return (alias: string): IField | undefined => {
        return state.rawFields.find((f) => f.alias === alias);
      };
    },
  },

  actions: {
    setRawFields(fields: IField[]): void {
      this.rawFields = fields;
    },

    async fetchFields(calcId: number): Promise<void> {
      const response = await api.getFields(calcId);
      this.rawFields = response.data;
    },
  },
});
```

### Using Stores in Components

```vue
<script setup lang="ts">
import { useBuilderStore } from '@/admin/app/providers/stores/useBuilderStore';
import { storeToRefs } from 'pinia';

// Get store instance
const builderStore = useBuilderStore();

// Reactive refs (use storeToRefs for reactivity)
const { rawFields, builderFields } = storeToRefs(builderStore);

// Actions (direct access, no need for storeToRefs)
const { setRawFields, fetchFields } = builderStore;

// Or call directly
builderStore.setRawFields(fields);

// Getters
const field = builderStore.getFieldByAlias('field_1');
</script>
```

### Don't Destructure State Directly

```typescript
// ❌ Bad - Loses reactivity
const { rawFields } = builderStore;

// ✅ Good - Maintains reactivity
const { rawFields } = storeToRefs(builderStore);
```

## Component Structure

```vue
<template>
  <!-- Template here -->
  <div class="calculator-field">
    <label>{{ props.label }}</label>
    <input v-model="localValue" @input="handleInput" />
  </div>
</template>

<script setup lang="ts">
/**
 * Calculator Field Component
 *
 * @description Input field for calculator
 */

// Imports
import { ref, computed, watch, onMounted } from 'vue';
import { useBuilderStore } from '@/stores/useBuilderStore';

// Types/Interfaces
interface Props {
  modelValue: string;
  label: string;
  required?: boolean;
}

// Props
const props = withDefaults(defineProps<Props>(), {
  required: false,
});

// Emits
const emit = defineEmits<{
  'update:modelValue': [value: string];
}>();

// Stores
const builderStore = useBuilderStore();

// Refs
const localValue = ref<string>(props.modelValue);

// Computed
const isValid = computed(() => {
  if (!props.required) return true;
  return localValue.value.length > 0;
});

// Methods
function handleInput() {
  emit('update:modelValue', localValue.value);
}

// Watchers
watch(
  () => props.modelValue,
  (newVal) => {
    localValue.value = newVal;
  }
);

// Lifecycle
onMounted(() => {
  console.log('Component mounted');
});
</script>

<style scoped>
.calculator-field {
  /* Styles here */
}
</style>
```

